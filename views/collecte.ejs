<%- include("partials/header", { title: title }) %>

<section class="split">
  <article class="card">
    <h2>Creer une collecte</h2>
    <% if (error) { %>
    <div class="alert error"><%= error %></div>
    <% } %>
    <form method="POST" action="/collecte/create" class="form-grid">
      <label for="name">Nom de la collecte</label>
      <input id="name" name="name" type="text" required />

      <label for="type">Type</label>
      <select id="type" name="type">
        <option value="offrande">Offrande</option>
        <option value="tontine">Tontine</option>
        <option value="contribution">Contribution</option>
        <option value="autre">Autre</option>
      </select>

      <div id="customTypeWrap" class="hidden">
        <label for="customType">Nom du type personnalise</label>
        <input id="customType" name="customType" type="text" placeholder="Ex: Dime speciale" />
      </div>

      <label for="date">Date</label>
      <input id="date" name="date" type="date" required />

      <button class="btn btn-primary" type="submit">Enregistrer la collecte</button>
    </form>
  </article>

  <article class="card">
    <h2>Selectionner une collecte</h2>
    <form method="GET" action="/collecte" class="form-grid">
      <label for="id">Collecte</label>
      <select id="id" name="id">
        <% collectes.forEach((item) => { %>
        <option value="<%= item.id %>" <%= selectedCollecte && selectedCollecte.id === item.id ? "selected" : "" %>>
          <%= item.name %> - <%= item.date %>
        </option>
        <% }) %>
      </select>
      <button type="submit" class="btn">Afficher</button>
    </form>
  </article>
</section>

<section class="card">
  <% if (!selectedCollecte) { %>
  <p class="muted">Aucune collecte selectionnee. Creez ou choisissez une collecte.</p>
  <% } else { %>
  <div class="section-head">
    <div>
      <h2><%= selectedCollecte.name %></h2>
      <p class="muted">
        Type: <%= selectedCollecte.type %> | Date: <%= selectedCollecte.date %>
      </p>
    </div>
    <div class="total-box">
      Total en temps reel:
      <strong id="totalValue"><%= Number(selectedCollecte.total).toLocaleString("fr-FR") %> FC</strong>
    </div>
  </div>

  <div class="actions">
    <a class="btn" href="/collecte/<%= selectedCollecte.id %>/export/pdf">Exporter PDF</a>
    <a class="btn" href="/collecte/<%= selectedCollecte.id %>/export/excel">Exporter Excel</a>
  </div>

  <article class="card">
    <h3>Personnes suivies (objectif par periode)</h3>
    <form method="POST" action="/collecte/<%= selectedCollecte.id %>/member/create" class="form-grid">
      <label for="memberName">Nom de la personne</label>
      <input id="memberName" name="name" type="text" required />

      <label for="memberTargetAmount">Montant prevu (FC)</label>
      <input id="memberTargetAmount" name="targetAmount" type="number" min="1" required />

      <label for="memberFrequency">Frequence</label>
      <select id="memberFrequency" name="frequency" required>
        <option value="journalier">Journalier</option>
        <option value="hebdomadaire">Hebdomadaire</option>
        <option value="mensuel" selected>Mensuel</option>
        <option value="annuel">Annuel</option>
      </select>

      <button type="submit" class="btn btn-primary">Ajouter la personne</button>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Personne</th>
            <th>Frequence</th>
            <th>Objectif</th>
            <th>Paye (periode courante)</th>
            <th>Statut</th>
            <th>Periode</th>
            <th>Modifier</th>
          </tr>
        </thead>
        <tbody>
          <% if (!memberStatuses || !memberStatuses.length) { %>
          <tr>
            <td colspan="7" class="muted">Aucune personne enregistree pour cette collecte.</td>
          </tr>
          <% } %>
          <% (memberStatuses || []).forEach((member) => { %>
          <tr>
            <td><%= member.name %></td>
            <td><%= member.frequency %></td>
            <td><%= Number(member.targetAmount).toLocaleString("fr-FR") %> FC</td>
            <td><%= Number(member.paidThisPeriod).toLocaleString("fr-FR") %> FC</td>
            <td>
              <% if (member.isCompleted) { %>
              <span class="status-badge done">Termine</span>
              <% } else { %>
              <span class="status-badge pending">En cours (<%= Number(member.remaining).toLocaleString("fr-FR") %> FC restants)</span>
              <% } %>
            </td>
            <td><%= member.periodLabel %></td>
            <td>
              <form
                method="POST"
                action="/collecte/<%= selectedCollecte.id %>/member/<%= member.id %>/update"
                class="form-grid member-edit-form"
              >
                <input name="name" type="text" value="<%= member.name %>" required />
                <input name="targetAmount" type="number" min="1" value="<%= member.targetAmount %>" required />
                <select name="frequency" required>
                  <option value="journalier" <%= member.frequency === "journalier" ? "selected" : "" %>>Journalier</option>
                  <option value="hebdomadaire" <%= member.frequency === "hebdomadaire" ? "selected" : "" %>>Hebdomadaire</option>
                  <option value="mensuel" <%= member.frequency === "mensuel" ? "selected" : "" %>>Mensuel</option>
                  <option value="annuel" <%= member.frequency === "annuel" ? "selected" : "" %>>Annuel</option>
                </select>
                <button type="submit" class="btn">Editer</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <form
    id="contributionForm"
    class="form-grid inline-form"
    data-collecte-id="<%= selectedCollecte.id %>"
  >
    <label for="memberId">Associer a une personne (optionnel)</label>
    <select id="memberId" name="memberId">
      <option value="">-- Aucune --</option>
      <% (memberStatuses || []).forEach((member) => { %>
      <option value="<%= member.id %>"><%= member.name %></option>
      <% }) %>
    </select>

    <label for="contributorName">Nom du contributeur</label>
    <input id="contributorName" name="contributorName" type="text" />

    <label for="amount">Montant</label>
    <input id="amount" name="amount" type="number" min="1" required />

    <button type="submit" class="btn btn-primary">Ajouter contribution</button>
  </form>

  <div id="feedback" class="alert hidden"></div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Contributeur</th>
          <th>Montant</th>
          <th>Personne suivie</th>
        </tr>
      </thead>
      <tbody id="contributionsBody">
        <% if (!selectedCollecte.contributions.length) { %>
        <tr id="emptyRow">
          <td colspan="3" class="muted">Aucune contribution pour le moment.</td>
        </tr>
        <% } %>
        <% selectedCollecte.contributions.forEach((contribution) => { %>
        <tr>
          <td><%= contribution.contributorName %></td>
          <td><%= Number(contribution.amount).toLocaleString("fr-FR") %> FC</td>
          <td>
            <%= contribution.memberId ? "Oui" : "Non" %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</section>

<script src="/js/collecte.js"></script>
<%- include("partials/footer") %>
