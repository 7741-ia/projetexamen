<%- include("partials/header", { title: title }) %>

<section class="hero card">
  <h1>Tableau de bord</h1>
  <p class="muted">Vue simple de ton activite. Commence par creer une collecte, puis ajoute les paiements.</p>
</section>

<section class="card">
  <h2>Guide rapide (3 etapes)</h2>
  <div class="help-steps">
    <article class="help-step">
      <span class="step-dot">1</span>
      <h3>Creer une collecte</h3>
      <p class="muted">Nom + type + date. Tu peux aussi choisir un type personnalise.</p>
    </article>
    <article class="help-step">
      <span class="step-dot">2</span>
      <h3>Ajouter les personnes</h3>
      <p class="muted">Definis un objectif et une frequence (jour, semaine, mois, annee).</p>
    </article>
    <article class="help-step">
      <span class="step-dot">3</span>
      <h3>Enregistrer les paiements</h3>
      <p class="muted">Le statut passe automatiquement a Termine quand l'objectif est atteint.</p>
    </article>
  </div>
</section>

<section class="stats-grid">
  <article class="card stat">
    <h2>Nombre de collectes</h2>
    <p><%= collectesCount %></p>
  </article>
  <article class="card stat">
    <h2>Total global</h2>
    <p><%= totalGlobal.toLocaleString("fr-FR") %> FC</p>
  </article>
</section>

<section class="card">
  <div class="section-head">
    <h2>Dernieres collectes</h2>
    <a class="btn btn-primary pulse-action" href="/collecte">Nouvelle collecte</a>
  </div>
  <% if (!latestCollectes.length) { %>
  <p class="muted">Aucune collecte enregistree.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Nom</th>
          <th>Type</th>
          <th>Date</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% latestCollectes.forEach((collecte) => { %>
        <tr>
          <td><%= collecte.name %></td>
          <td><%= collecte.type %></td>
          <td><%= collecte.date %></td>
          <td><%= Number(collecte.total).toLocaleString("fr-FR") %> FC</td>
          <td><a href="/collecte?id=<%= collecte.id %>">Ouvrir</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</section>

<%- include("partials/footer") %>
